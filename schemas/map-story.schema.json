{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moltpany/Agent-Mappy/schemas/map-story.schema.json",
  "title": "Agent-Mappy Map Story Entries",
  "description": "A JSON array of source-grounded map story entries.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "id",
      "year",
      "city",
      "country",
      "lat",
      "lng",
      "work",
      "catalogue",
      "genre",
      "context",
      "meaning",
      "source"
    ],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "year": { "type": "integer" },
      "city": { "type": "string", "minLength": 1 },
      "country": { "type": "string", "minLength": 1 },
      "lat": { "type": "number", "minimum": -90, "maximum": 90 },
      "lng": { "type": "number", "minimum": -180, "maximum": 180 },
      "work": { "type": "string", "minLength": 1 },
      "catalogue": { "type": "string", "minLength": 1 },
      "genre": { "type": "string", "minLength": 1 },
      "context": { "type": "string", "minLength": 1 },
      "meaning": { "type": "string", "minLength": 1 },
      "source": { "$ref": "#/$defs/source" },
      "place": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "address", "kind", "certainty", "note", "lat", "lng", "source"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "address": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "certainty": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 },
          "lat": { "type": "number", "minimum": -90, "maximum": 90 },
          "lng": { "type": "number", "minimum": -180, "maximum": 180 },
          "source": { "$ref": "#/$defs/source" },
          "image": {
            "type": "object",
            "additionalProperties": true,
            "required": ["url", "alt", "caption", "sourceLabel", "sourceUrl"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "alt": { "type": "string", "minLength": 1 },
              "caption": { "type": "string", "minLength": 1 },
              "sourceLabel": { "type": "string", "minLength": 1 },
              "sourceUrl": { "type": "string", "format": "uri" }
            }
          }
        }
      },
      "collections": {
        "type": "array",
        "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "uniqueItems": true
      },
      "listening": {
        "type": "object",
        "additionalProperties": true,
        "required": ["target"],
        "properties": {
          "target": { "type": "string", "minLength": 1 },
          "note": { "type": "string" },
          "bilibiliSearch": { "type": "string", "format": "uri" },
          "youtubeSearch": { "type": "string", "format": "uri" },
          "appleMusicSearch": { "type": "string", "format": "uri" },
          "spotifySearch": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "url", "summary"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
